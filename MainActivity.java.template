    private void renderClientPanel() {
        final String destination = prefs.getString("destination", "");
        final boolean requested = prefs.getBoolean("client_requested", false);

        if (requested) {
            panelSubtitle.setText(destination.length() > 0
                    ? "Solicitação enviada para: " + destination
                    : "Solicitação enviada. Aguardando confirmação do motorista.");
        } else {
            panelSubtitle.setText("Motorista disponível próximo.");
        }

        primaryButton = goldButton(requested ? "Atualizar acompanhamento" : "Solicitar transporte neste local");
        primaryButton.setOnClickListener(new View.OnClickListener() {
            @Override public void onClick(View v) {
                prefs.edit().putBoolean("client_requested", true).apply();
                Toast.makeText(MainActivity.this, "Solicitação registrada no modo local.", Toast.LENGTH_SHORT).show();
                renderRolePanel();
            }
        });
        bottomPanel.addView(primaryButton, fullButtonLp());

        Button destinationButton = outlineButton("Destino / Para onde?");
        destinationButton.setOnClickListener(new View.OnClickListener() {
            @Override public void onClick(View v) { showDestinationDialog(); }
        });
        bottomPanel.addView(destinationButton, fullButtonLp());

        Button connectionButton = outlineButton("Configurar conexão da central");
        connectionButton.setOnClickListener(new View.OnClickListener() {
            @Override public void onClick(View v) { showConnectionDialog(); }
        });
        bottomPanel.addView(connectionButton, fullButtonLp());
    }

    private void renderDriverPanel() {
