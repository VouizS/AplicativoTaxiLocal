    private LinearLayout dialogBox() {
        LinearLayout box = new LinearLayout(this);
        box.setOrientation(LinearLayout.VERTICAL);
        box.setPadding(dp(22), dp(22), dp(22), dp(22));
        box.setBackground(cardBg(PANEL, dp(24), dp(1), GOLD));
        return box;
    }

    private ScrollView wrapScroll(LinearLayout box) {
        ScrollView scroll = new ScrollView(this);
        scroll.setFillViewport(false);
        scroll.setPadding(dp(18), dp(18), dp(18), dp(18));
        scroll.addView(box);
        return scroll;
    }

    private void showDialogWindow(Dialog dialog) {
        dialog.show();
        Window w = dialog.getWindow();
        if (w != null) {
            w.setBackgroundDrawableResource(android.R.color.transparent);
            w.setLayout((int) (getResources().getDisplayMetrics().widthPixels * 0.92f), FrameLayout.LayoutParams.WRAP_CONTENT);
        }
    }

