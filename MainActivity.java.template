            addInfoLine(box, "Destino", destination);
        } else {
            addInfoLine(box, "Status", motoristaOnline ? "online" : "offline");
            addInfoLine(box, "Veículo", prefs.getString("vehicle_model", "Sedan executivo"));
        }

        Button close = goldButton("Fechar");
        close.setOnClickListener(new View.OnClickListener() {
