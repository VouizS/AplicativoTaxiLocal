    private void showDestinationDialog() {
        final Dialog dialog = premiumDialog();
        LinearLayout box = dialogBox();

        addDialogTitle(box, "Para onde você vai?");
        addDialogSubtitle(box, "Digite o destino ou escolha um ponto rápido.");

        final EditText input = premiumField("Ex.: rodoviária, hospital, hotel, bairro...");
        input.setText(prefs.getString("destination", ""));
        box.addView(input, fieldLp());

        HorizontalScrollView scroller = new HorizontalScrollView(this);
        scroller.setHorizontalScrollBarEnabled(false);
        LinearLayout chips = new LinearLayout(this);
        chips.setOrientation(LinearLayout.HORIZONTAL);

        String[] quick = {"Centro", "Rodoviária", "Hospital", "Hotel", "Casa", "Trabalho"};
        for (final String item : quick) {
            Button chip = smallChip(item);
            chip.setOnClickListener(new View.OnClickListener() {
                @Override public void onClick(View v) { input.setText(item); input.setSelection(input.getText().length()); }
            });
            LinearLayout.LayoutParams chipLp = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, dp(42));
            chipLp.setMargins(0, 0, dp(8), 0);
            chips.addView(chip, chipLp);
        }

        scroller.addView(chips);
        box.addView(scroller);

        LinearLayout actions = actionRow();
        Button cancel = outlineButton("Cancelar");
        Button save = goldButton("Confirmar destino");
        cancel.setOnClickListener(new View.OnClickListener() {
            @Override public void onClick(View v) { dialog.dismiss(); }
        });
        save.setOnClickListener(new View.OnClickListener() {
            @Override public void onClick(View v) {
                String value = input.getText().toString().trim();
                if (value.length() == 0) {
                    Toast.makeText(MainActivity.this, "Informe um destino.", Toast.LENGTH_SHORT).show();
                    return;
                }
                prefs.edit().putString("destination", value).apply();
                Toast.makeText(MainActivity.this, "Destino salvo.", Toast.LENGTH_SHORT).show();
                dialog.dismiss();
                renderRolePanel();
            }
        });
        actions.addView(cancel, actionButtonLp());
        actions.addView(space(dp(10), 1));
        actions.addView(save, actionButtonLp());
        box.addView(actions);

        dialog.setContentView(wrapScroll(box));
        showDialogWindow(dialog);
    }

