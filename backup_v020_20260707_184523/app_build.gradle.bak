plugins { id 'com.android.application' }

android {
    namespace 'com.sw.viaprime'
    compileSdk 35

    defaultConfig {
        applicationId 'com.sw.viaprime'
        minSdk 23
        targetSdk 35
        versionCode 13
        versionName "0.2.0"
    }

    // Via Prime v0.2.0 split apps
    flavorDimensions "role"

    productFlavors {
        cliente {
            dimension "role"
            applicationId "com.swviaprime.cliente"
        }
        motorista {
            dimension "role"
            applicationId "com.swviaprime.motoristas"
        }
    }
}

dependencies {
    implementation 'org.osmdroid:osmdroid-android:6.1.18'
}
